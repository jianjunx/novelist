# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=novelist
DB_SSLMODE=disable

# JWT密钥（必须修改）
JWT_SECRET=your-secret-key-change-this

# 服务器端口
SERVER_PORT=8080

# DeepSeek API配置
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# 可选：其他模型API密钥
# CLAUDE_API_KEY=
# OPENAI_API_KEY=
